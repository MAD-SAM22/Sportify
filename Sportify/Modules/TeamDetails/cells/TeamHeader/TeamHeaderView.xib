<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="13142" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="12042"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <view contentMode="scaleToFill" id="iN0-l3-epB" customClass="TeamHeaderView" customModule="Sportify" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="375" height="260"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>
                <!-- Banner Image -->
                <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFill" translatesAutoresizingMaskIntoConstraints="NO" id="banner-id">
                    <rect key="frame" x="16" y="16" width="343" height="180"/>
                    <color key="backgroundColor" red="0.15" green="0.18" blue="0.28" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                    <userDefinedRuntimeAttributes>
                        <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                            <integer key="value" value="16"/>
                        </userDefinedRuntimeAttribute>
                        <userDefinedRuntimeAttribute type="boolean" keyPath="layer.masksToBounds" value="YES"/>
                    </userDefinedRuntimeAttributes>
                </imageView>
                <!-- Team Logo -->
                <imageView clipsSubviews="YES" userInteractionEnabled="NO" contentMode="scaleAspectFill" translatesAutoresizingMaskIntoConstraints="NO" id="logo-id">
                    <rect key="frame" x="20" y="146" width="60" height="60"/>
                    <color key="backgroundColor" red="0.3" green="0.3" blue="0.4" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                    <userDefinedRuntimeAttributes>
                        <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                            <integer key="value" value="30"/>
                        </userDefinedRuntimeAttribute>
                        <userDefinedRuntimeAttribute type="boolean" keyPath="layer.masksToBounds" value="YES"/>
                        <userDefinedRuntimeAttribute type="number" keyPath="layer.borderWidth">
                            <real key="value" value="2"/>
                        </userDefinedRuntimeAttribute>
                    </userDefinedRuntimeAttributes>
                </imageView>
                <!-- Team Name -->
                <label opaque="NO" userInteractionEnabled="NO" contentMode="left" horizontalHuggingPriority="251" verticalHuggingPriority="251" translatesAutoresizingMaskIntoConstraints="NO" id="name-id">
                    <rect key="frame" x="0" y="216" width="375" height="36"/>
                    <fontDescription key="fontDescription" type="boldSystem" pointSize="28"/>
                    <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                    <nil key="highlightedColor"/>
                    <string key="text">Team Name</string>
                    <userDefinedRuntimeAttributes>
                        <userDefinedRuntimeAttribute type="number" keyPath="textAlignment">
                            <integer key="value" value="1"/>
                        </userDefinedRuntimeAttribute>
                    </userDefinedRuntimeAttributes>
                </label>
            </subviews>
            <color key="backgroundColor" red="0.08" green="0.10" blue="0.18" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
            <constraints>
                <constraint firstItem="banner-id" firstAttribute="top" secondItem="iN0-l3-epB" secondAttribute="top" constant="16" id="c1"/>
                <constraint firstItem="banner-id" firstAttribute="leading" secondItem="iN0-l3-epB" secondAttribute="leading" constant="16" id="c2"/>
                <constraint firstAttribute="trailing" secondItem="banner-id" secondAttribute="trailing" constant="16" id="c3"/>
                <constraint firstItem="banner-id" firstAttribute="height" constant="180" id="c4"/>
                <constraint firstItem="logo-id" firstAttribute="leading" secondItem="iN0-l3-epB" secondAttribute="leading" constant="20" id="c5"/>
                <constraint firstItem="logo-id" firstAttribute="centerY" secondItem="banner-id" secondAttribute="bottom" id="c6"/>
                <constraint firstItem="logo-id" firstAttribute="width" constant="60" id="c7"/>
                <constraint firstItem="logo-id" firstAttribute="height" constant="60" id="c8"/>
                <constraint firstItem="name-id" firstAttribute="top" secondItem="logo-id" secondAttribute="bottom" constant="12" id="c9"/>
                <constraint firstItem="name-id" firstAttribute="leading" secondItem="iN0-l3-epB" secondAttribute="leading" id="c10"/>
                <constraint firstAttribute="trailing" secondItem="name-id" secondAttribute="trailing" id="c11"/>
                <constraint firstAttribute="bottom" secondItem="name-id" secondAttribute="bottom" constant="8" id="c12"/>
            </constraints>
            <connections>
                <outlet property="bannerImageView" destination="banner-id" id="o1"/>
                <outlet property="teamLogoImageView" destination="logo-id" id="o2"/>
                <outlet property="teamNameLabel" destination="name-id" id="o3"/>
            </connections>
            <viewLayoutGuide key="safeArea" id="vUN-kp-3ea"/>
        </view>
    </objects>
</document>
