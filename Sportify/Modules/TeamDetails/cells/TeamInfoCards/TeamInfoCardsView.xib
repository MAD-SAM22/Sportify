<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="13142" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="12042"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <view contentMode="scaleToFill" id="iN0-l3-epB" customClass="TeamInfoCardsView" customModule="Sportify" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="375" height="110"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>

                <!-- Horizontal StackView: 3 equal cards -->
                <stackView opaque="NO" contentMode="scaleToFill"
                           axis="horizontal" distribution="fillEqually" spacing="12"
                           translatesAutoresizingMaskIntoConstraints="NO" id="hstack-id">
                    <rect key="frame" x="16" y="8" width="343" height="94"/>
                    <subviews>

                        <!-- ── COUNTRY CARD ── -->
                        <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="country-card-id">
                            <color key="backgroundColor" red="0.12" green="0.15" blue="0.25" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                            <userDefinedRuntimeAttributes>
                                <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                                    <integer key="value" value="12"/>
                                </userDefinedRuntimeAttribute>
                                <userDefinedRuntimeAttribute type="boolean" keyPath="layer.masksToBounds" value="YES"/>
                            </userDefinedRuntimeAttributes>
                            <subviews>
                                <stackView opaque="NO" contentMode="scaleToFill"
                                           axis="vertical" alignment="center" spacing="3"
                                           translatesAutoresizingMaskIntoConstraints="NO" id="cv-vstack">
                                    <subviews>
                                        <!-- Icon -->
                                        <label opaque="NO" userInteractionEnabled="NO"
                                               text="🌐" textAlignment="center"
                                               translatesAutoresizingMaskIntoConstraints="NO" id="country-icon-id">
                                            <fontDescription key="fontDescription" type="system" pointSize="22"/>
                                            <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                            <nil key="highlightedColor"/>
                                        </label>
                                        <!-- Key -->
                                        <label opaque="NO" userInteractionEnabled="NO"
                                               text="Country:" textAlignment="center"
                                               translatesAutoresizingMaskIntoConstraints="NO" id="country-key-id">
                                            <fontDescription key="fontDescription" type="system" pointSize="11"/>
                                            <color key="textColor" red="1" green="1" blue="1" alpha="0.6" colorSpace="custom" customColorSpace="sRGB"/>
                                            <nil key="highlightedColor"/>
                                        </label>
                                        <!-- Value -->
                                        <label opaque="NO" userInteractionEnabled="NO"
                                               text="England" textAlignment="center" numberOfLines="2"
                                               translatesAutoresizingMaskIntoConstraints="NO" id="country-value-id">
                                            <fontDescription key="fontDescription" type="boldSystem" pointSize="13"/>
                                            <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                            <nil key="highlightedColor"/>
                                        </label>
                                    </subviews>
                                </stackView>
                            </subviews>
                            <constraints>
                                <constraint firstItem="cv-vstack" firstAttribute="centerX" secondItem="country-card-id" secondAttribute="centerX" id="cv-cx"/>
                                <constraint firstItem="cv-vstack" firstAttribute="centerY" secondItem="country-card-id" secondAttribute="centerY" id="cv-cy"/>
                                <constraint firstItem="cv-vstack" firstAttribute="leading" secondItem="country-card-id" secondAttribute="leading" constant="8" id="cv-l"/>
                                <constraint firstAttribute="trailing" secondItem="cv-vstack" secondAttribute="trailing" constant="8" id="cv-r"/>
                            </constraints>
                        </view>

                        <!-- ── STADIUM CARD ── -->
                        <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="stadium-card-id">
                            <color key="backgroundColor" red="0.12" green="0.15" blue="0.25" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                            <userDefinedRuntimeAttributes>
                                <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                                    <integer key="value" value="12"/>
                                </userDefinedRuntimeAttribute>
                                <userDefinedRuntimeAttribute type="boolean" keyPath="layer.masksToBounds" value="YES"/>
                            </userDefinedRuntimeAttributes>
                            <subviews>
                                <stackView opaque="NO" contentMode="scaleToFill"
                                           axis="vertical" alignment="center" spacing="3"
                                           translatesAutoresizingMaskIntoConstraints="NO" id="sv-vstack">
                                    <subviews>
                                        <label opaque="NO" userInteractionEnabled="NO"
                                               text="🏟️" textAlignment="center"
                                               translatesAutoresizingMaskIntoConstraints="NO" id="stadium-icon-id">
                                            <fontDescription key="fontDescription" type="system" pointSize="22"/>
                                            <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                            <nil key="highlightedColor"/>
                                        </label>
                                        <label opaque="NO" userInteractionEnabled="NO"
                                               text="Stadium:" textAlignment="center"
                                               translatesAutoresizingMaskIntoConstraints="NO" id="stadium-key-id">
                                            <fontDescription key="fontDescription" type="system" pointSize="11"/>
                                            <color key="textColor" red="1" green="1" blue="1" alpha="0.6" colorSpace="custom" customColorSpace="sRGB"/>
                                            <nil key="highlightedColor"/>
                                        </label>
                                        <label opaque="NO" userInteractionEnabled="NO"
                                               text="Stamford Bridge" textAlignment="center" numberOfLines="2"
                                               translatesAutoresizingMaskIntoConstraints="NO" id="stadium-value-id">
                                            <fontDescription key="fontDescription" type="boldSystem" pointSize="13"/>
                                            <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                            <nil key="highlightedColor"/>
                                        </label>
                                    </subviews>
                                </stackView>
                            </subviews>
                            <constraints>
                                <constraint firstItem="sv-vstack" firstAttribute="centerX" secondItem="stadium-card-id" secondAttribute="centerX" id="sv-cx"/>
                                <constraint firstItem="sv-vstack" firstAttribute="centerY" secondItem="stadium-card-id" secondAttribute="centerY" id="sv-cy"/>
                                <constraint firstItem="sv-vstack" firstAttribute="leading" secondItem="stadium-card-id" secondAttribute="leading" constant="8" id="sv-l"/>
                                <constraint firstAttribute="trailing" secondItem="sv-vstack" secondAttribute="trailing" constant="8" id="sv-r"/>
                            </constraints>
                        </view>

                        <!-- ── FOUNDED CARD ── -->
                        <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="founded-card-id">
                            <color key="backgroundColor" red="0.12" green="0.15" blue="0.25" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                            <userDefinedRuntimeAttributes>
                                <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                                    <integer key="value" value="12"/>
                                </userDefinedRuntimeAttribute>
                                <userDefinedRuntimeAttribute type="boolean" keyPath="layer.masksToBounds" value="YES"/>
                            </userDefinedRuntimeAttributes>
                            <subviews>
                                <stackView opaque="NO" contentMode="scaleToFill"
                                           axis="vertical" alignment="center" spacing="3"
                                           translatesAutoresizingMaskIntoConstraints="NO" id="fv-vstack">
                                    <subviews>
                                        <label opaque="NO" userInteractionEnabled="NO"
                                               text="📅" textAlignment="center"
                                               translatesAutoresizingMaskIntoConstraints="NO" id="founded-icon-id">
                                            <fontDescription key="fontDescription" type="system" pointSize="22"/>
                                            <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                            <nil key="highlightedColor"/>
                                        </label>
                                        <label opaque="NO" userInteractionEnabled="NO"
                                               text="Founded:" textAlignment="center"
                                               translatesAutoresizingMaskIntoConstraints="NO" id="founded-key-id">
                                            <fontDescription key="fontDescription" type="system" pointSize="11"/>
                                            <color key="textColor" red="1" green="1" blue="1" alpha="0.6" colorSpace="custom" customColorSpace="sRGB"/>
                                            <nil key="highlightedColor"/>
                                        </label>
                                        <label opaque="NO" userInteractionEnabled="NO"
                                               text="1905" textAlignment="center"
                                               translatesAutoresizingMaskIntoConstraints="NO" id="founded-value-id">
                                            <fontDescription key="fontDescription" type="boldSystem" pointSize="13"/>
                                            <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                                            <nil key="highlightedColor"/>
                                        </label>
                                    </subviews>
                                </stackView>
                            </subviews>
                            <constraints>
                                <constraint firstItem="fv-vstack" firstAttribute="centerX" secondItem="founded-card-id" secondAttribute="centerX" id="fv-cx"/>
                                <constraint firstItem="fv-vstack" firstAttribute="centerY" secondItem="founded-card-id" secondAttribute="centerY" id="fv-cy"/>
                                <constraint firstItem="fv-vstack" firstAttribute="leading" secondItem="founded-card-id" secondAttribute="leading" constant="8" id="fv-l"/>
                                <constraint firstAttribute="trailing" secondItem="fv-vstack" secondAttribute="trailing" constant="8" id="fv-r"/>
                            </constraints>
                        </view>

                    </subviews>
                </stackView>

            </subviews>

            <!-- Pin stack to root view -->
            <constraints>
                <constraint firstItem="hstack-id" firstAttribute="top" secondItem="iN0-l3-epB" secondAttribute="top" constant="8" id="hs-t"/>
                <constraint firstItem="hstack-id" firstAttribute="leading" secondItem="iN0-l3-epB" secondAttribute="leading" constant="16" id="hs-l"/>
                <constraint firstAttribute="trailing" secondItem="hstack-id" secondAttribute="trailing" constant="16" id="hs-r"/>
                <constraint firstAttribute="bottom" secondItem="hstack-id" secondAttribute="bottom" constant="8" id="hs-b"/>
            </constraints>

            <color key="backgroundColor" red="0.08" green="0.10" blue="0.18" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
            <viewLayoutGuide key="safeArea" id="vUN-kp-3ea"/>

            <connections>
                <outlet property="countryCard"       destination="country-card-id"   id="o-cc"/>
                <outlet property="stadiumCard"       destination="stadium-card-id"   id="o-sc"/>
                <outlet property="foundedCard"       destination="founded-card-id"   id="o-fc"/>
                <outlet property="countryValueLabel" destination="country-value-id"  id="o-cv"/>
                <outlet property="stadiumValueLabel" destination="stadium-value-id"  id="o-sv"/>
                <outlet property="foundedValueLabel" destination="founded-value-id"  id="o-fv"/>
            </connections>
        </view>
    </objects>
</document>
