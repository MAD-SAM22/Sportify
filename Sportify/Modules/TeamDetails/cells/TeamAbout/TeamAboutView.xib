<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="13142" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="12042"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <view contentMode="scaleToFill" id="iN0-l3-epB" customClass="TeamAboutView" customModule="Sportify" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="375" height="180"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>

                <!-- Card Container -->
                <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="about-card-id">
                    <rect key="frame" x="16" y="8" width="343" height="164"/>
                    <color key="backgroundColor" red="0.10" green="0.13" blue="0.22" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                    <userDefinedRuntimeAttributes>
                        <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                            <integer key="value" value="16"/>
                        </userDefinedRuntimeAttribute>
                        <userDefinedRuntimeAttribute type="boolean" keyPath="layer.masksToBounds" value="YES"/>
                    </userDefinedRuntimeAttributes>
                    <subviews>

                        <!-- Title Label -->
                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left"
                               translatesAutoresizingMaskIntoConstraints="NO" id="about-title-id">
                            <rect key="frame" x="16" y="16" width="311" height="24"/>
                            <string key="text">About the Team</string>
                            <fontDescription key="fontDescription" type="boldSystem" pointSize="18"/>
                            <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                            <nil key="highlightedColor"/>
                        </label>

                        <!-- Description Label -->
                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left"
                               numberOfLines="0"
                               translatesAutoresizingMaskIntoConstraints="NO" id="about-desc-id">
                            <rect key="frame" x="16" y="48" width="311" height="100"/>
                            <string key="text">Team description goes here. This label will expand based on content.</string>
                            <fontDescription key="fontDescription" type="system" pointSize="14"/>
                            <color key="textColor" red="1" green="1" blue="1" alpha="0.75" colorSpace="custom" customColorSpace="sRGB"/>
                            <nil key="highlightedColor"/>
                        </label>

                    </subviews>

                    <!-- Card internal constraints -->
                    <constraints>
                        <constraint firstItem="about-title-id" firstAttribute="top" secondItem="about-card-id" secondAttribute="top" constant="16" id="title-top"/>
                        <constraint firstItem="about-title-id" firstAttribute="leading" secondItem="about-card-id" secondAttribute="leading" constant="16" id="title-lead"/>
                        <constraint firstAttribute="trailing" secondItem="about-title-id" secondAttribute="trailing" constant="16" id="title-trail"/>

                        <constraint firstItem="about-desc-id" firstAttribute="top" secondItem="about-title-id" secondAttribute="bottom" constant="8" id="desc-top"/>
                        <constraint firstItem="about-desc-id" firstAttribute="leading" secondItem="about-card-id" secondAttribute="leading" constant="16" id="desc-lead"/>
                        <constraint firstAttribute="trailing" secondItem="about-desc-id" secondAttribute="trailing" constant="16" id="desc-trail"/>
                        <constraint firstAttribute="bottom" secondItem="about-desc-id" secondAttribute="bottom" constant="16" id="desc-bot"/>
                    </constraints>
                </view>

            </subviews>

            <!-- Outer constraints pinning card to root view -->
            <constraints>
                <constraint firstItem="about-card-id" firstAttribute="top" secondItem="iN0-l3-epB" secondAttribute="top" constant="8" id="card-top"/>
                <constraint firstItem="about-card-id" firstAttribute="leading" secondItem="iN0-l3-epB" secondAttribute="leading" constant="16" id="card-lead"/>
                <constraint firstAttribute="trailing" secondItem="about-card-id" secondAttribute="trailing" constant="16" id="card-trail"/>
                <constraint firstAttribute="bottom" secondItem="about-card-id" secondAttribute="bottom" constant="8" id="card-bot"/>
            </constraints>

            <color key="backgroundColor" red="0.08" green="0.10" blue="0.18" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
            <viewLayoutGuide key="safeArea" id="vUN-kp-3ea"/>

            <!-- IBOutlet connections -->
            <connections>
                <outlet property="containerCard" destination="about-card-id" id="out-card"/>
                <outlet property="titleLabel" destination="about-title-id" id="out-title"/>
                <outlet property="descriptionLabel" destination="about-desc-id" id="out-desc"/>
            </connections>
        </view>
    </objects>
</document>
