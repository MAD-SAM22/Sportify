<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="13142" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="12042"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <view contentMode="scaleToFill" id="iN0-l3-epB" customClass="TeamPlayersView" customModule="Sportify" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="375" height="150"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>

                <!-- OUTER CARD -->
                <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="players-card-id">
                    <rect key="frame" x="16" y="8" width="343" height="134"/>
                    <color key="backgroundColor" red="0.10" green="0.13" blue="0.22" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                    <userDefinedRuntimeAttributes>
                        <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                            <integer key="value" value="16"/>
                        </userDefinedRuntimeAttribute>
                        <userDefinedRuntimeAttribute type="boolean" keyPath="layer.masksToBounds" value="YES"/>
                    </userDefinedRuntimeAttributes>
                    <subviews>

                        <!-- Title Label -->
                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left"
                               translatesAutoresizingMaskIntoConstraints="NO" id="players-title-id">
                            <rect key="frame" x="16" y="14" width="311" height="22"/>
                            <string key="text">Players</string>
                            <fontDescription key="fontDescription" type="boldSystem" pointSize="18"/>
                            <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                            <nil key="highlightedColor"/>
                        </label>

                        <!-- Horizontal ScrollView -->
                        <scrollView clipsSubviews="YES" multipleTouchEnabled="YES"
                                    contentMode="scaleToFill" showsHorizontalScrollIndicator="NO"
                                    showsVerticalScrollIndicator="NO"
                                    translatesAutoresizingMaskIntoConstraints="NO" id="scroll-view-id">
                            <rect key="frame" x="0" y="44" width="343" height="82"/>
                            <color key="backgroundColor" red="0" green="0" blue="0" alpha="0" colorSpace="custom" customColorSpace="sRGB"/>
                            <subviews>

                                <!-- Horizontal StackView inside ScrollView -->
                                <stackView opaque="NO" contentMode="scaleToFill"
                                           axis="horizontal" spacing="12"
                                           alignment="center"
                                           translatesAutoresizingMaskIntoConstraints="NO" id="players-hstack-id">
                                    <rect key="frame" x="16" y="0" width="0" height="82"/>
                                </stackView>

                            </subviews>

                            <!-- ScrollView content constraints -->
                            <constraints>
                                <constraint firstItem="players-hstack-id" firstAttribute="top" secondItem="scroll-view-id" secondAttribute="top" id="hs-t"/>
                                <constraint firstItem="players-hstack-id" firstAttribute="bottom" secondItem="scroll-view-id" secondAttribute="bottom" id="hs-b"/>
                                <constraint firstItem="players-hstack-id" firstAttribute="leading" secondItem="scroll-view-id" secondAttribute="leading" constant="16" id="hs-l"/>
                                <constraint firstAttribute="trailing" secondItem="players-hstack-id" secondAttribute="trailing" constant="16" id="hs-r"/>
                                <constraint firstItem="players-hstack-id" firstAttribute="height" secondItem="scroll-view-id" secondAttribute="height" id="hs-h"/>
                            </constraints>
                        </scrollView>

                    </subviews>

                    <!-- Card internal constraints -->
                    <constraints>
                        <constraint firstItem="players-title-id" firstAttribute="top" secondItem="players-card-id" secondAttribute="top" constant="14" id="pt-t"/>
                        <constraint firstItem="players-title-id" firstAttribute="leading" secondItem="players-card-id" secondAttribute="leading" constant="16" id="pt-l"/>
                        <constraint firstAttribute="trailing" secondItem="players-title-id" secondAttribute="trailing" constant="16" id="pt-r"/>

                        <constraint firstItem="scroll-view-id" firstAttribute="top" secondItem="players-title-id" secondAttribute="bottom" constant="8" id="sv-t"/>
                        <constraint firstItem="scroll-view-id" firstAttribute="leading" secondItem="players-card-id" secondAttribute="leading" id="sv-l"/>
                        <constraint firstAttribute="trailing" secondItem="scroll-view-id" secondAttribute="trailing" id="sv-r"/>
                        <constraint firstAttribute="bottom" secondItem="scroll-view-id" secondAttribute="bottom" constant="8" id="sv-b"/>
                    </constraints>
                </view>

            </subviews>

            <!-- Outer constraints -->
            <constraints>
                <constraint firstItem="players-card-id" firstAttribute="top" secondItem="iN0-l3-epB" secondAttribute="top" constant="8" id="oc-t"/>
                <constraint firstItem="players-card-id" firstAttribute="leading" secondItem="iN0-l3-epB" secondAttribute="leading" constant="16" id="oc-l"/>
                <constraint firstAttribute="trailing" secondItem="players-card-id" secondAttribute="trailing" constant="16" id="oc-r"/>
                <constraint firstAttribute="bottom" secondItem="players-card-id" secondAttribute="bottom" constant="8" id="oc-b"/>
            </constraints>

            <color key="backgroundColor" red="0.08" green="0.10" blue="0.18" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
            <viewLayoutGuide key="safeArea" id="vUN-kp-3ea"/>

            <connections>
                <outlet property="titleLabel"      destination="players-title-id"   id="out-title"/>
                <outlet property="scrollView"      destination="scroll-view-id"     id="out-scroll"/>
                <outlet property="playersStackView" destination="players-hstack-id" id="out-stack"/>
            </connections>
        </view>
    </objects>
</document>
