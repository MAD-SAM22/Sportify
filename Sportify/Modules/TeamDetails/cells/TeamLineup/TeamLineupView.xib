<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<document type="com.apple.InterfaceBuilder3.CocoaTouch.XIB" version="3.0" toolsVersion="13142" targetRuntime="iOS.CocoaTouch" propertyAccessControl="none" useAutolayout="YES" useTraitCollections="YES" useSafeAreas="YES" colorMatched="YES">
    <dependencies>
        <plugIn identifier="com.apple.InterfaceBuilder.IBCocoaTouchPlugin" version="12042"/>
        <capability name="Safe area layout guides" minToolsVersion="9.0"/>
        <capability name="documents saved in the Xcode 8 format" minToolsVersion="8.0"/>
    </dependencies>
    <objects>
        <placeholder placeholderIdentifier="IBFilesOwner" id="-1" userLabel="File's Owner"/>
        <placeholder placeholderIdentifier="IBFirstResponder" id="-2" customClass="UIResponder"/>
        <view contentMode="scaleToFill" id="iN0-l3-epB" customClass="TeamLineupView" customModule="Sportify" customModuleProvider="target">
            <rect key="frame" x="0.0" y="0.0" width="375" height="420"/>
            <autoresizingMask key="autoresizingMask" widthSizable="YES" heightSizable="YES"/>
            <subviews>

                <!-- ── OUTER CARD (green pitch container) ── -->
                <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="pitch-card-id">
                    <rect key="frame" x="16" y="8" width="343" height="404"/>
                    <color key="backgroundColor" red="0.10" green="0.13" blue="0.22" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                    <userDefinedRuntimeAttributes>
                        <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                            <integer key="value" value="16"/>
                        </userDefinedRuntimeAttribute>
                        <userDefinedRuntimeAttribute type="boolean" keyPath="layer.masksToBounds" value="YES"/>
                    </userDefinedRuntimeAttributes>
                    <subviews>

                        <!-- Title Label -->
                        <label opaque="NO" userInteractionEnabled="NO" contentMode="left"
                               translatesAutoresizingMaskIntoConstraints="NO" id="lineup-title-id">
                            <rect key="frame" x="16" y="16" width="311" height="24"/>
                            <string key="text">Team Lineup</string>
                            <fontDescription key="fontDescription" type="boldSystem" pointSize="18"/>
                            <color key="textColor" white="1" alpha="1" colorSpace="custom" customColorSpace="genericGamma22GrayColorSpace"/>
                            <nil key="highlightedColor"/>
                        </label>

                        <!-- Green Pitch View -->
                        <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="pitch-view-id">
                            <rect key="frame" x="16" y="52" width="311" height="336"/>
                            <color key="backgroundColor" red="0.13" green="0.50" blue="0.13" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
                            <userDefinedRuntimeAttributes>
                                <userDefinedRuntimeAttribute type="number" keyPath="layer.cornerRadius">
                                    <integer key="value" value="12"/>
                                </userDefinedRuntimeAttribute>
                                <userDefinedRuntimeAttribute type="boolean" keyPath="layer.masksToBounds" value="YES"/>
                            </userDefinedRuntimeAttributes>
                            <subviews>

                                <!-- Pitch Lines (decorative center circle) -->
                                <view contentMode="scaleToFill" translatesAutoresizingMaskIntoConstraints="NO" id="center-line-id">
                                    <rect key="frame" x="0" y="158" width="311" height="1"/>
                                    <color key="backgroundColor" red="1" green="1" blue="1" alpha="0.2" colorSpace="custom" customColorSpace="sRGB"/>
                                </view>

                                <!-- Players StackView (rows of players on pitch) -->
                                <stackView opaque="NO" contentMode="scaleToFill"
                                           axis="vertical" alignment="fill"
                                           distribution="equalSpacing" spacing="8"
                                           translatesAutoresizingMaskIntoConstraints="NO" id="players-stack-id">
                                    <rect key="frame" x="8" y="12" width="295" height="312"/>
                                </stackView>

                            </subviews>

                            <!-- Pitch internal constraints -->
                            <constraints>
                                <constraint firstItem="center-line-id" firstAttribute="leading" secondItem="pitch-view-id" secondAttribute="leading" id="cl-l"/>
                                <constraint firstAttribute="trailing" secondItem="center-line-id" secondAttribute="trailing" id="cl-r"/>
                                <constraint firstItem="center-line-id" firstAttribute="centerY" secondItem="pitch-view-id" secondAttribute="centerY" id="cl-cy"/>
                                <constraint firstItem="center-line-id" firstAttribute="height" constant="1" id="cl-h"/>

                                <constraint firstItem="players-stack-id" firstAttribute="top" secondItem="pitch-view-id" secondAttribute="top" constant="12" id="ps-t"/>
                                <constraint firstItem="players-stack-id" firstAttribute="leading" secondItem="pitch-view-id" secondAttribute="leading" constant="8" id="ps-l"/>
                                <constraint firstAttribute="trailing" secondItem="players-stack-id" secondAttribute="trailing" constant="8" id="ps-r"/>
                                <constraint firstAttribute="bottom" secondItem="players-stack-id" secondAttribute="bottom" constant="12" id="ps-b"/>
                            </constraints>
                        </view>

                    </subviews>

                    <!-- Card internal constraints -->
                    <constraints>
                        <constraint firstItem="lineup-title-id" firstAttribute="top" secondItem="pitch-card-id" secondAttribute="top" constant="16" id="lt-t"/>
                        <constraint firstItem="lineup-title-id" firstAttribute="leading" secondItem="pitch-card-id" secondAttribute="leading" constant="16" id="lt-l"/>
                        <constraint firstAttribute="trailing" secondItem="lineup-title-id" secondAttribute="trailing" constant="16" id="lt-r"/>

                        <constraint firstItem="pitch-view-id" firstAttribute="top" secondItem="lineup-title-id" secondAttribute="bottom" constant="12" id="pv-t"/>
                        <constraint firstItem="pitch-view-id" firstAttribute="leading" secondItem="pitch-card-id" secondAttribute="leading" constant="16" id="pv-l"/>
                        <constraint firstAttribute="trailing" secondItem="pitch-view-id" secondAttribute="trailing" constant="16" id="pv-r"/>
                        <constraint firstAttribute="bottom" secondItem="pitch-view-id" secondAttribute="bottom" constant="16" id="pv-b"/>
                    </constraints>
                </view>

            </subviews>

            <!-- Outer constraints pinning card to root view -->
            <constraints>
                <constraint firstItem="pitch-card-id" firstAttribute="top" secondItem="iN0-l3-epB" secondAttribute="top" constant="8" id="oc-t"/>
                <constraint firstItem="pitch-card-id" firstAttribute="leading" secondItem="iN0-l3-epB" secondAttribute="leading" constant="16" id="oc-l"/>
                <constraint firstAttribute="trailing" secondItem="pitch-card-id" secondAttribute="trailing" constant="16" id="oc-r"/>
                <constraint firstAttribute="bottom" secondItem="pitch-card-id" secondAttribute="bottom" constant="8" id="oc-b"/>
            </constraints>

            <color key="backgroundColor" red="0.08" green="0.10" blue="0.18" alpha="1" colorSpace="custom" customColorSpace="sRGB"/>
            <viewLayoutGuide key="safeArea" id="vUN-kp-3ea"/>

            <connections>
                <outlet property="titleLabel"    destination="lineup-title-id"  id="out-title"/>
                <outlet property="pitchView"     destination="pitch-view-id"    id="out-pitch"/>
                <outlet property="stackView"     destination="players-stack-id" id="out-stack"/>
            </connections>
        </view>
    </objects>
</document>
